{
  "name": "billet",
  "description": "Billet is a terminal-based AI coding agent built from scratch with the Anthropic Claude API, Bun, and TypeScript",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/main.ts",
    "format": "oxfmt --write \"**/*.{ts,tsx,js,jsx}\"",
    "lint": "oxlint",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "verify": "bun format && bun lint && bun typecheck && bun test",
    "eval": "node --env-file=.env.local node_modules/.bin/evalite run",
    "eval:ui": "node --env-file=.env.local node_modules/.bin/evalite serve",
    "demo": "rm -rf /tmp/billet-demo && mkdir -p /tmp/billet-demo && vhs demo/billet.tape"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "autoevals": "^0.0.132",
    "bindings": "^1.5.0",
    "evalite": "^0.19.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.52.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "^0.0.42",
    "@anthropic-ai/sdk": "^0.78.0",
    "arktype": "^2.2.0"
  }
}
